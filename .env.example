# ─────────────────────────────────────────────────────────────────────
# ORION Brief v5 — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
SECRET_KEY=change-this-to-a-random-64-char-hex-string

# ── Email delivery (Gmail recommended) ───────────────────────────────
# Gmail App Password: myaccount.google.com/apppasswords
# Enable 2FA first → Security → App Passwords → create new
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ── Razorpay payments ─────────────────────────────────────────────────
# Keys from: https://dashboard.razorpay.com/app/keys
# Use TEST keys (rzp_test_...) first, switch to LIVE (rzp_live_...) for production
# Leave blank → demo mode, payments simulated (no real charges)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_SECRET=your_razorpay_secret

# ── Razorpay Subscriptions plan IDs (auto-filled on first run) ────────
# After first subscriber, app prints these IDs — paste them here
# so Razorpay plans aren't recreated on every restart
# RAZORPAY_PLAN_ID_BRIEF=plan_xxxxxxxxxxxx
# RAZORPAY_PLAN_ID_STANDARD=plan_xxxxxxxxxxxx
# RAZORPAY_PLAN_ID_FULL=plan_xxxxxxxxxxxx

# ── Razorpay webhook (for auto-renewal) ───────────────────────────────
# In Razorpay dashboard → Settings → Webhooks → add:
#   URL: https://your-domain.com/api/payment/webhook
#   Secret: same as RAZORPAY_SECRET above
#   Events: subscription.charged, subscription.cancelled, subscription.expired

# ── Admin panel ───────────────────────────────────────────────────────
# Set to your login email — bypasses paywall, shows /admin link in topbar
ADMIN_EMAIL=your-admin-email@gmail.com

# ── Domain + SSL ──────────────────────────────────────────────────────
# Set to your domain after certbot SSL is configured
# Used in email links, invoice download URLs, payment confirmation
BASE_URL=https://oriontintel.in
# BASE_URL=https://orion-brief-production.up.railway.app

# ── ACLED API (verified conflict data — free academic license) ────────
# Register at: https://developer.acleddata.com/
# Free for research — commercial use requires license
ACLED_API_KEY=your_acled_key
ACLED_EMAIL=your-email@gmail.com

# ── NewsAPI (English news feed) ───────────────────────────────────────
# Register at: https://newsapi.org/register
# Free tier: 100 requests/day (sufficient — we fetch once per day)
NEWSAPI_KEY=your_newsapi_key

# ── GST invoice details ───────────────────────────────────────────────
# Shown on every invoice — register GST at gst.gov.in once revenue > ₹20L
# Leave GST_NUMBER blank until registered — invoice will show a warning
GST_NUMBER=
BUSINESS_NAME=ORION Intelligence Technologies
BUSINESS_ADDR=Guwahati, Assam, India - 781001

# ── Auto-set by Railway / platform ───────────────────────────────────
# PORT=5000
